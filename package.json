{
	"name": "json-viewer",
	"description": "manifest.json description",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "wxt build",
		"build:coverage": "E2E_COVERAGE=1 wxt build",
		"build:firefox": "wxt build -b firefox",
		"compile": "tsc --noEmit",
		"coverage:all": "bun run test:coverage && bun run test:e2e:coverage && bun run coverage:merge",
		"coverage:merge": "bun scripts/merge-coverage.ts",
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"format": "biome format --write",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"postinstall": "wxt prepare",
		"pretest:e2e": "playwright install chromium",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:coverage": "bun run build:coverage && E2E_COVERAGE=1 playwright test",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox"
	},
	"dependencies": {
		"@fontsource/geist": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@playwright/test": "^1.59.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.2",
		"@wxt-dev/module-react": "^1.1.5",
		"happy-dom": "^20.8.9",
		"monocart-reporter": "^2.10.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.2",
		"wxt": "^0.20.20"
	}
}
